#include "resource.h"

IDD_SETTINGS_DIALOG DIALOG 0, 0, 380, 200
STYLE 0x80C80080
CAPTION "Gemini Balance Settings"
FONT 9, "MS Shell Dlg"
BEGIN
    LTEXT           "GCP Service Account JSON (paste full content):", IDC_SA_JSON_LABEL, 10, 10, 360, 10
    EDITTEXT        IDC_SA_JSON_EDIT, 10, 22, 360, 50, 0x00800044

    LTEXT           "Monthly Budget ($):", IDC_BUDGET_LABEL, 10, 85, 100, 10
    EDITTEXT        IDC_BUDGET_EDIT, 10, 97, 80, 14, 0x80

    LTEXT           "Refresh Interval (min):", IDC_FETCH_INTERVAL_LABEL, 120, 85, 110, 10
    EDITTEXT        IDC_FETCH_INTERVAL_EDIT, 120, 97, 60, 14, 0x80

    PUSHBUTTON      "Refresh Now", IDC_REFRESH_BUTTON, 200, 95, 80, 18

    LTEXT           "Status: —", IDC_AUTH_STATUS, 10, 125, 360, 20

    DEFPUSHBUTTON   "OK", IDOK, 200, 165, 60, 20
    PUSHBUTTON      "Cancel", IDCANCEL, 280, 165, 60, 20
END
