#include "resource.h"

IDD_SETTINGS_DIALOG DIALOG 0, 0, 380, 210
STYLE 0x80C80080
CAPTION "Codex Balance Settings"
FONT 9, "MS Shell Dlg"
BEGIN
    LTEXT           "Session Cookie (Priority 1):", IDC_SESSION_COOKIE_LABEL, 10, 10, 360, 10
    EDITTEXT        IDC_SESSION_COOKIE_EDIT, 10, 22, 360, 14, 0xA0
    LTEXT           "Provides full billing access (balance + usage)", 0, 20, 38, 200, 10

    LTEXT           "API Key — fallback (Priority 2):", IDC_API_KEY_LABEL, 10, 55, 360, 10
    EDITTEXT        IDC_API_KEY_EDIT, 10, 67, 360, 14, 0xA0

    LTEXT           "Monthly Budget ($):", IDC_BUDGET_LABEL, 10, 92, 100, 10
    EDITTEXT        IDC_BUDGET_EDIT, 10, 104, 80, 14, 0x80

    LTEXT           "Refresh Interval (min):", IDC_FETCH_INTERVAL_LABEL, 120, 92, 110, 10
    EDITTEXT        IDC_FETCH_INTERVAL_EDIT, 120, 104, 60, 14, 0x80

    PUSHBUTTON      "Refresh Now", IDC_REFRESH_BUTTON, 200, 102, 80, 18

    LTEXT           "Auth: —", IDC_AUTH_STATUS, 10, 130, 360, 10

    DEFPUSHBUTTON   "OK", IDOK, 220, 170, 60, 20
    PUSHBUTTON      "Cancel", IDCANCEL, 300, 170, 60, 20
END
