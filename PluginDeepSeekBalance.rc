#include "resource.h"

IDD_SETTINGS_DIALOG DIALOG 0, 0, 320, 140
STYLE 0x80C80080
CAPTION "DeepSeek Balance Settings"
FONT 9, "MS Shell Dlg"
BEGIN
    LTEXT           "DeepSeek API Key:", IDC_API_KEY_LABEL, 10, 15, 100, 10
    EDITTEXT        IDC_API_KEY_EDIT, 10, 30, 300, 14, 0xA0
    LTEXT           "Refresh Interval (min):", IDC_FETCH_INTERVAL_LABEL, 10, 55, 100, 10
    EDITTEXT        IDC_FETCH_INTERVAL_EDIT, 10, 70, 80, 14, 0x80
    DEFPUSHBUTTON   "OK", IDOK, 170, 100, 60, 20
    PUSHBUTTON      "Cancel", IDCANCEL, 250, 100, 60, 20
END
