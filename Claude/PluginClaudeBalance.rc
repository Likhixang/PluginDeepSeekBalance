#include "resource.h"

IDD_SETTINGS_DIALOG DIALOG 0, 0, 340, 160
STYLE 0x80C80080
CAPTION "Claude Balance Settings"
FONT 9, "MS Shell Dlg"
BEGIN
    LTEXT           "Admin API Key (sk-ant-admin-...):", IDC_API_KEY_LABEL, 10, 15, 320, 10
    EDITTEXT        IDC_API_KEY_EDIT, 10, 30, 320, 14, 0xA0

    LTEXT           "Monthly Budget ($):", IDC_BUDGET_LABEL, 10, 55, 100, 10
    EDITTEXT        IDC_BUDGET_EDIT, 10, 67, 80, 14, 0x80

    LTEXT           "Refresh Interval (min):", IDC_FETCH_INTERVAL_LABEL, 120, 55, 110, 10
    EDITTEXT        IDC_FETCH_INTERVAL_EDIT, 120, 67, 60, 14, 0x80

    PUSHBUTTON      "Refresh Now", IDC_REFRESH_BUTTON, 200, 65, 80, 18

    DEFPUSHBUTTON   "OK", IDOK, 160, 120, 60, 20
    PUSHBUTTON      "Cancel", IDCANCEL, 240, 120, 60, 20
END
